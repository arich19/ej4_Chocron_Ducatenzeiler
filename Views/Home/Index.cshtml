@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>
<form>
    <h3> Datos Personales</h3>
    Nombre Completo: <input type="text" name="nombre">
    Edad: <input type="number" name="edad">
    Dni: <input type="number" name="dni">
    <h3> Situacion Laboral</h3>
    actualmente trabaja?: <input type = "radio" name="trabaja">
    cual es su tipo de empleo?: <select name="tipo de empleo">
    <option value ="relacion de dependencia">relacion de dependencia<option>
    <option value ="monontributista">monoitributista<option>
    <option value ="autonomo">autonomo<option>
    <option value ="desempleado">desempleado<option>
    <h3> Situacion Economica</h3>
    ingreso mensual: <input type ="number" name="ingreso">
    ¿Posee otras deudas?: <input type="radio" name="deudas">
    En caso afirmativo, seleccione cuáles:
        <input type="checkbox" name="deuda" value="tarjeta de credito"> Tarjeta de credito<br>
        <input type="checkbox" name="deuda" value="bancario"> Préstamo bancario<br>
        <input type="checkbox" name="deuda" value="informal"> Préstamo informal
    <h3>Condiciones del préstamo</h3>
    Monto solicitado: <ipnut type="number" name="monto">
    Plazo de devolución: <select name="plazo">
    <option value ="6">6 meses<option>
    <option value ="12">12 meses<option>
    <option value ="24">24 meses<option>
    <h3> CONFIRMAR PRESTAMO</h3>
    <ipnut type="checkbox" name="TyC"> Acepto lo terminos y Condiciones
    <input type="submit"> Enviar
</form>
